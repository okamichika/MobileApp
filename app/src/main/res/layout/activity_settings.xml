<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".activity.Settings">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#F0D6BF"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:background="#122840"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/imageView2"
                android:layout_width="100dp"
                android:layout_height="match_parent"
                app:srcCompat="@drawable/logo" />

            <TextView
                android:id="@+id/textView3"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:paddingLeft="35dp"
                android:text="Paramètres"
                android:textColor="#FEFEFE"
                android:textSize="40sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginVertical="20dp"
            android:orientation="vertical">

            <Button
                android:id="@+id/button7"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="35dp"
                android:height="60dp"
                android:backgroundTint="#ABC8B6"
                android:text="changer la langue"
                android:textColor="@color/black"
                android:textSize="25sp"
                app:cornerRadius="0dp"
                app:strokeWidth="1dp" />

            <Button
                android:id="@+id/button8"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="35dp"
                android:height="60dp"
                android:backgroundTint="#F4BD4F"
                android:text="modifier mote de passe"
                android:textColor="@color/black"
                android:textSize="25sp"
                app:cornerRadius="0dp"
                app:strokeWidth="1dp" />

            <Button
                android:id="@+id/button9"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="35dp"
                android:height="60dp"
                android:backgroundTint="#F4BD4F"
                android:text="se déconnecter"
                android:textColor="@color/black"
                android:textSize="25sp"
                app:cornerRadius="0dp"
                app:strokeWidth="1dp" />

            <Button
                android:id="@+id/button10"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="35dp"
                android:height="60dp"
                android:backgroundTint="#BB4B56"
                android:text="supprimer le compte"
                android:textColor="@color/black"
                android:textSize="25sp"
                app:cornerRadius="0dp"
                app:strokeWidth="1dp" />

            <Button
                android:id="@+id/button11"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="35dp"
                android:height="60dp"
                android:backgroundTint="#ABC8B6"
                android:text="contacter le support"
                android:textColor="@color/black"
                android:textSize="25sp"
                app:cornerRadius="0dp"
                app:strokeWidth="1dp" />

            <Button
                android:id="@+id/Baccueil"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="10dp"
                android:layout_marginBottom="20dp"
                android:height="80dp"
                android:backgroundTint="#ABC8B6"
                android:text="Retour à l'accueil"
                android:textColor="@color/black"
                android:textSize="25sp"
                app:cornerRadius="0dp"
                app:strokeWidth="1dp" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>